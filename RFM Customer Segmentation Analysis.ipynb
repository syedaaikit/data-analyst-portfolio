import pandas as pd
import datetime as dt

# Load a sample dataset (using a URL for easy access)
url = 'https://archive.ics.uci.edu/ml/machine-learning-databases/00352/Online%20Retail.xlsx'
df = pd.read_excel(url)

# Clean up: Remove rows with no CustomerID and negative prices
df = df.dropna(subset=['CustomerID'])
df = df[df['Quantity'] > 0]

print(df.head())
# Create a TotalPrice column
df['TotalSum'] = df['Quantity'] * df['UnitPrice']
# Set snapshot date
snapshot_date = df['InvoiceDate'].max() + dt.timedelta(days=1)

# Group by CustomerID to calculate RFM values
rfm = df.groupby('CustomerID').agg({
    'InvoiceDate': lambda x: (snapshot_date - x.max()).days, # Recency
    'InvoiceNo': 'count',                                   # Frequency
    'TotalSum': 'sum'                                       # Monetary
})

# Rename columns for clarity
rfm.rename(columns={'InvoiceDate': 'Recency',
                     'InvoiceNo': 'Frequency',
                     'TotalSum': 'MonetaryValue'}, inplace=True)

print(rfm.head())
# 1. Assign scores from 1 to 5 (5 is the best)
# For Recency, a lower number of days is better, so we reverse the labels
r_labels = range(5, 0, -1)
f_labels = range(1, 6)
m_labels = range(1, 6)

# 2. Cut the data into 5 groups for each metric
rfm['R'] = pd.qcut(rfm['Recency'], q=5, labels=r_labels)
rfm['F'] = pd.qcut(rfm['Frequency'], q=5, labels=f_labels)
rfm['M'] = pd.qcut(rfm['MonetaryValue'], q=5, labels=m_labels)

# 3. Create a combined RFM Score (e.g., "555" is your best customer)
rfm['RFM_Group'] = rfm.R.astype(str) + rfm.F.astype(str) + rfm.M.astype(str)
rfm['RFM_Score'] = rfm[['R', 'F', 'M']].sum(axis=1)

print(rfm.head())
# Define a function to name the segments based on the score
def segment_me(df):
    if df['RFM_Score'] >= 12:
        return 'Champions (Best Customers)'
    elif (df['RFM_Score'] >= 9) and (df['RFM_Score'] < 12):
        return 'Loyal Customers'
    elif (df['RFM_Score'] >= 6) and (df['RFM_Score'] < 9):
        return 'At Risk / Need Attention'
    else:
        return 'Lost Customers'

# Apply the naming function
rfm['Segment'] = rfm.apply(segment_me, axis=1)

# See how many customers are in each group
print(rfm['Segment'].value_counts())
import matplotlib.pyplot as plt

# Plot the segments
rfm['Segment'].value_counts().plot(kind='barh', color='teal')
plt.title('Customer Segments by RFM Score')
plt.xlabel('Number of Customers')
plt.show()
import pandas as pd
import datetime as dt
import matplotlib.pyplot as plt
import squarify
import numpy as np

# 1. LOAD & CLEAN DATA
url = 'https://archive.ics.uci.edu/ml/machine-learning-databases/00352/Online%20Retail.xlsx'
df = pd.read_excel(url)
df = df.dropna(subset=['CustomerID'])
df = df[df['Quantity'] > 0]
df['TotalSum'] = df['Quantity'] * df['UnitPrice']

# 2. CALCULATE RFM
snapshot_date = df['InvoiceDate'].max() + dt.timedelta(days=1)
rfm = df.groupby('CustomerID').agg({
    'InvoiceDate': lambda x: (snapshot_date - x.max()).days,
    'InvoiceNo': 'count',
    'TotalSum': 'sum'
})
rfm.rename(columns={'InvoiceDate': 'Recency', 'InvoiceNo': 'Frequency', 'TotalSum': 'MonetaryValue'}, inplace=True)

# 3. SCORING (1-5)
rfm['R'] = pd.qcut(rfm['Recency'], q=5, labels=range(5, 0, -1))
rfm['F'] = pd.qcut(rfm['Frequency'], q=5, labels=range(1, 6))
rfm['M'] = pd.qcut(rfm['MonetaryValue'], q=5, labels=range(1, 6))
rfm['RFM_Score'] = rfm[['R', 'F', 'M']].sum(axis=1)

# 4. SEGMENTATION
def segment_me(x):
    if x >= 12: return 'Champions'
    elif x >= 9: return 'Loyal'
    elif x >= 6: return 'At Risk'
    else: return 'Lost'

rfm['Segment'] = rfm['RFM_Score'].apply(segment_me)

# 5. PREPARE TREEMAP DATA
segment_analysis = rfm.groupby('Segment').agg({
    'Recency': 'count',
    'MonetaryValue': 'sum'
}).rename(columns={'Recency': 'Count', 'MonetaryValue': 'Revenue'})

# 6. VISUALIZE
plt.figure(figsize=(12, 8))
labels = [f"{label}\n{count} Users\n${int(rev):,}" 
          for label, count, rev in zip(segment_analysis.index, 
                                       segment_analysis['Count'], 
                                       segment_analysis['Revenue'])]

squarify.plot(sizes=segment_analysis['Count'], label=labels, 
              color=['#008080', '#20B2AA', '#FFA500', '#FF6347'], alpha=0.7, pad=True)

plt.title('Customer Segment Treemap', fontsize=16)
plt.axis('off')
plt.show()
# Filter for perfect scores
vips = rfm[(rfm['R'] == 5) & (rfm['F'] == 5) & (rfm['M'] == 5)]

# Sort by MonetaryValue to see the biggest spenders first
vips = vips.sort_values('MonetaryValue', ascending=False)

print(f"You have {len(vips)} VIP customers.")
print(vips.head())
# Calculate VIP contribution
total_revenue = rfm['MonetaryValue'].sum()
vip_revenue = vips['MonetaryValue'].sum()
vip_percentage = (vip_revenue / total_revenue) * 100

print(f"VIPs represent {vip_percentage:.2f}% of your total revenue.")
# Save to CSV
vips.to_csv('vip_customers_list.csv')
print("VIP list saved to 'vip_customers_list.csv'!")
# Calculate mean recency per segment
recency_stats = rfm.groupby('Segment')['Recency'].mean().sort_values()

print("Average Days Since Last Purchase:")
print(recency_stats)
plt.figure(figsize=(10, 6))
recency_stats.plot(kind='bar', color=['#008080', '#20B2AA', '#FFA500', '#FF6347'])

plt.title('Average Days Since Last Purchase by Segment', fontsize=14)
plt.xlabel('Customer Segment', fontsize=12)
plt.ylabel('Average Recency (Days)', fontsize=12)
plt.xticks(rotation=45)
plt.grid(axis='y', linestyle='--', alpha=0.7)

# Add data labels on top of bars
for i, v in enumerate(recency_stats):
    plt.text(i, v + 2, f"{int(v)} days", ha='center', fontweight='bold')

plt.tight_layout()
plt.show()
import seaborn as sns

# Create a pivot table counting customers for each R and F score
rfm_pivoted = rfm.pivot_table(index='R', columns='F', values='MonetaryValue', aggfunc='count')

# Fill any NaN values with 0 (in case a specific combination has no customers)
rfm_pivoted = rfm_pivoted.fillna(0)
plt.figure(figsize=(10, 8))
sns.heatmap(rfm_pivoted, annot=True, fmt='g', cmap='YlGnBu', cbar_kws={'label': 'Number of Customers'})

plt.title('Customer Density: Recency vs. Frequency', fontsize=16, pad=20)
plt.xlabel('Frequency Score (1=Low, 5=High)', fontsize=12)
plt.ylabel('Recency Score (1=Old, 5=Recent)', fontsize=12)

# Flip the Y-axis so 5 (Most Recent) is at the top
plt.gca().invert_yaxis() 

plt.show()
